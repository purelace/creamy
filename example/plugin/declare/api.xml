<?xml version="1.0" encoding="UTF-8" ?>
<protocol name="api" version="0" access="exclusive_write">
    <message name="GetNextIndex">
        <field name="index" type="u32" />
    </message>

    <!--
    <message name="get_used_indices">
        <field name="len" type="u16" />
        <field name="data" type="{len}" />
    </message>
    -->

    <message name="GetBucket">
        <field name="bucket_idx" type="u32" />
    </message>

    <message name="GetBucketResult">
        <field name="status" type="Status" />
        <field name="value" type="Bucket" />
    </message>

    <struct name="Bucket">
        <field name="a" type="u8" />
        <field name="b" type="u8" />
        <field name="c" type="u8" />
    </struct>

    <enum name="Status">
        <variant name="Error" />
        <variant name="Allow" />
        <variant name="Deny" />
    </enum>

</protocol>
<!--
    * Access types: [exclusive_write(01), multiple_write(02)]

    * Numeric types: [
        u8, u16, u32, u64, u128,
        i8, i16, i32, i64, i128,
        f32, f64,
    ]

    * Other: [
        fixed-size arrays [numeric_type; length],
        field: {field_name},
    ]

    * Custom: [
        enum, struct
    ]
-->
