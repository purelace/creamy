<?xml version="1.0" encoding="UTF-8" ?>
<protocol name="api" version="0" access="exclusive_write">
    <message name="get_next_index">
        <field name="index" type="u32" />
    </message>

    <message name="get_used_indices">
        <field name="len" type="u16" />
        <field name="data" type="{len}" />
    </message>

    <message name="get_bucket">
        <field name="index" type="u32" />
    </message>

    <message name="get_bucket_result">
        <field name="status" type="status" />
        <field name="value" type="bucket" />
    </message>

    <struct name="bucket">
        <field name="a" type="u8" />
        <field name="b" type="u8" />
        <field name="c" type="u8" />
    </struct>

    <enum name="status">
        <variant name="error" />
        <variant name="allow" />
        <variant name="deny" />
    </enum>

</protocol>
<!--
    * Access types: [exclusive_write(01), multiple_write(02)]

    * Numeric types: [
        u8, u16, u32, u64, u128,
        i8, i16, i32, i64, i128,
        f32, f64,
    ]

    * Other: [
        fixed-size arrays [numeric_type; length],
        field: {field_name},
    ]

    * Custom: [
        enum, struct
    ]
-->
